generator client {
  provider = "prisma-client-js"
  output   = "../generated/sqlite-client"
}

datasource db {
  provider = "sqlite"
  url      = env("SQLITE_DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Student {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  floor        Int
  room         String?
  fullName     String?
  note         String?
  telegramId   String?  @unique
  isFrozen     Boolean  @default(false)
  frozenReason String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  duties   DutyStudent[]
  payments Payment[]

  @@index([floor])
  @@index([isFrozen])
}

model Duty {
  id        Int           @id @default(autoincrement())
  date      DateTime      @unique
  status    String        @default("pending")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  students  DutyStudent[]
}

model DutyStudent {
  id        Int      @id @default(autoincrement())
  dutyId    Int
  studentId Int
  floor     Int
  createdAt DateTime @default(now())

  duty      Duty    @relation(fields: [dutyId], references: [id], onDelete: Cascade)
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([dutyId, studentId])
  @@index([dutyId])
  @@index([studentId])
}

model RotationQueue {
  id               Int      @id @default(autoincrement())
  studentId        Int      @unique
  floor            Int
  lastAssignedDate DateTime?
  priority         Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([floor])
  @@index([priority])
}

model Settings {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payment {
  id          Int      @id @default(autoincrement())
  studentId   Int
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  amount      Float
  month       String
  status      String   @default("pending")
  imageUrl    String?
  submittedAt DateTime @default(now())
  reviewedAt  DateTime?
  reviewedBy  String?
  note        String?

  @@index([studentId])
  @@index([month])
  @@index([status])
}
