generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int     @id @default(autoincrement())
  email     String  @unique
  password  String
  name      String
  role      String  @default("admin") // admin, manager
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model Student {
  id        Int     @id @default(autoincrement())
  username  String  @unique
  floor     Int     // 1-4
  room      String? // Room number
  fullName  String? // Full name
  note      String? // Additional notes
  telegramId String? @unique
  isFrozen  Boolean @default(false)
  frozenReason String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  duties    DutyStudent[]
  payments  Payment[]

  @@index([floor])
  @@index([isFrozen])
}

model Duty {
  id        Int     @id @default(autoincrement())
  date      DateTime @unique
  status    String  @default("pending") // pending, posted, completed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  students  DutyStudent[]
}

model DutyStudent {
  id        Int     @id @default(autoincrement())
  dutyId    Int
  studentId Int
  floor     Int     // Which floor they're assigned to
  createdAt DateTime @default(now())

  duty      Duty    @relation(fields: [dutyId], references: [id], onDelete: Cascade)
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([dutyId, studentId])
  @@index([dutyId])
  @@index([studentId])
}

model RotationQueue {
  id        Int     @id @default(autoincrement())
  studentId Int     @unique
  floor     Int
  lastAssignedDate DateTime?
  priority  Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([floor])
  @@index([priority])
}

model Settings {
  id        Int     @id @default(autoincrement())
  key       String  @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

model Payment {
  id          Int      @id @default(autoincrement())
  studentId   Int
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  amount      Float
  month       String   // e.g., "2026-04" for April 2026
  status      String   @default("pending") // pending, confirmed, rejected
  imageUrl    String?  // Telegram file_id or URL
  submittedAt DateTime @default(now())
  reviewedAt  DateTime?
  reviewedBy  String?  // Admin username
  note        String?  // Additional notes
  
  @@index([studentId])
  @@index([month])
  @@index([status])
}
